# RESEND_FROM="Constructor ERP <onboarding@resend.dev>"
#
# Option B — Brevo / Sendinblue HTTPS API (free 300/day = 9000/month; cloud-host friendly)
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
# BREVO_FROM="Constructor ERP <your-verified-sender@example.com>"
#
# Option C — Generic SMTP (works locally; often blocked on cloud free tiers)
